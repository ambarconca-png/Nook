# Pflicht: Postgres-Passwort für den DB-Container auf dem VPS.
# Erzeugen mit:  openssl rand -base64 32 | tr -d '/+=' | head -c 32
POSTGRES_PASSWORD=CHANGE_ME

# Persönliches Nook-Konto. Beim ersten erfolgreichen Login wird es sicher
# in Postgres angelegt; das Passwort selbst wird nicht in der DB gespeichert.
NOOK_ADMIN_EMAIL=ambar@example.com
NOOK_ADMIN_PASSWORD=CHANGE_TO_A_LONG_RANDOM_PASSWORD
NOOK_ADMIN_NAME=Ambar

# Optional (Defaults sind sinnvoll):
# POSTGRES_DB=nook
# POSTGRES_USER=nook

# Nur lokal (nicht in Docker) — dann direkt setzen:
# DATABASE_URL=postgres://nook:CHANGE_ME@localhost:5432/nook
